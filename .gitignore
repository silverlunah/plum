#-----------------------#
#   Common .gitignore   #
#-----------------------#
# Node.js dependencies
/node_modules/

# Environment files
.env

# Logs
*.log

# Local node-runner PID registry (managed by scripts/manage-runners.mjs)
.runners.local.json

# Node operator identity + auth token (written by `plum node start`)
.plum-node.json

# Server config (written by `plum server start` / reconfig)
.plum-server.json

# Temporary files
*.tmp
*.swp

# npm package lock file (optional, if you don't want it in version control)
# package-lock.json

# OS-specific files
.DS_Store
Thumbs.db

# Coverage folder (if you're using a code coverage tool like Istanbul)
/coverage/

docker-compose.override.yml
.plum/

#-----------------------#
#   Backend .gitignore  #
#-----------------------#

# Playwright tests, test results and reports
/backend/tests/
/backend/test-results/
/backend/reports/
/backend/node_modules/

# Cron Job Config
/backend/config/cron-jobs.json

# Global Settings
/backend/config/settings.json

#-----------------------#
#  Frontend .gitignore  #
#-----------------------#
/frontend/node_modules/

# Output
/frontend/.output
/frontend/.vercel
/frontend/.netlify
/frontend/.wrangler
/frontend/.svelte-kit
/frontend/build

# OS
/frontend/.DS_Store
/frontend/Thumbs.db

# Env
/frontend/.env
/frontend/.env.*
!/frontend/.env.example
!/frontend/.env.test

# Vite
/frontend/vite.config.js.timestamp-*
/frontend/vite.config.ts.timestamp-*
backend/config/*.bak
